# =========================================
# Theta Indigo Spotify Podcast — ENV Template
# Copy this file to .env.local for local dev
# All values below are set as GitHub Secrets
# =========================================

# Cloudflare R2 Storage (transit audio + RSS feed)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=theta-indigo
R2_PUBLIC_URL=https://pub-3dfac1ebd38a458faff5626cae902ad2.r2.dev

# Telegram Bot (sukses/gagal reporting)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Firebase Admin SDK (paste entire JSON as single line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"theta-indigo",...}

# Cloudflare D1 — untuk ambil artikel blog
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_cf_api_token

# AI Keys (opsional, backup)
GROQ_API_KEY=your_groq_key
