# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=theta-indigo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=theta-indigo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=theta-indigo.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# AI API Configuration (Choose one provider)
# Option 1: Gemini (Recommended - Free)
GEMINI_API_KEY=your_gemini_api_key

# Option 2: OpenAI (Alternative)
# OPENAI_API_KEY=your_openai_api_key

# Option 3: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Option 4: Cohere
# COHERE_API_KEY=your_cohere_api_key

# Option 5: Local Ollama (Free)
# OLLAMA_BASE_URL=http://localhost:11434

# R2 Cloudflare Configuration (Optional - for image storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=theta-indigo

# Kredensial Midtrans
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_SERVER_KEY=your_midtrans_server_key

# Firebase Admin untuk API Midtrans server-side
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"theta-indigo","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@theta-indigo.iam.gserviceaccount.com"}

# Konfigurasi AI
DEEPSEEK_API_KEY=your_deepseek_or_openrouter_key
GROQ_API_KEY=your_groq_api_key

# TinyMCE API Key (Optional - for rich text editor)
NEXT_PUBLIC_TINYMCE_API_KEY=your_tinymce_api_key
