{
  "name": "theta-indigo-spotify",
  "version": "1.0.0",
  "description": "Theta Indigo Podcast automation — RSS + MP3 generator for Spotify",
  "private": true,
  "scripts": {
    "podcast": "ts-node --project tsconfig.json scripts/run-podcast.ts",
    "podcast:dry": "ts-node --project tsconfig.json scripts/run-podcast.ts --dry-run",
    "setup:cover": "ts-node --project tsconfig.json scripts/upload-cover.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.3.0",
    "google-tts-api": "^2.0.2",
    "msedge-tts": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
